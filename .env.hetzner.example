# Trap House Production Environment (Hetzner)
# Copy to .env and adjust values for your VPS.

# Production ports: real ports on the VPS.
# Endlessh takes port 22 (the VPS SSH must move to a high port, see deploy/harden.sh).
ENDLESSH_PORT=22
COWRIE_SSH_PORT=2222
COWRIE_TELNET_PORT=2223
DECEPTION_PORT=80
GRAFANA_PORT=3000
FRONTEND_PORT=8001

# Canarytokens (disabled by default, enable when ready)
ENABLE_CANARYTOKENS=false
# CANARYTOKEN_URL=https://canarytokens.org/...

# Session secret for deception-gw. CHANGE THIS to a random string.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX_STRING

# Grafana admin password. CHANGE THIS.
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Log retention (days)
LOG_RETENTION_DAYS=90
DB_RETENTION_DAYS=180

# SQLite path
SQLITE_PATH=/data/db/trap-house.db