# Trap House Environment Configuration
# Copy to .env and adjust as needed

# Ports (local dev uses high ports to avoid host conflicts)
ENDLESSH_PORT=22222
COWRIE_SSH_PORT=2222
COWRIE_TELNET_PORT=2223
DECEPTION_PORT=8080
GRAFANA_PORT=3000
FRONTEND_PORT=8001

# Production ports (use .env.hetzner for production)
# ENDLESSH_PORT=22
# DECEPTION_PORT=80

# Canarytokens
ENABLE_CANARYTOKENS=false
# CANARYTOKEN_URL=https://canarytokens.org/...

# Log retention (days)
LOG_RETENTION_DAYS=90
DB_RETENTION_DAYS=180

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme

# SQLite
SQLITE_PATH=/data/db/trap-house.db